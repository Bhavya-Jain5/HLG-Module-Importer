    {
      "name": "HLGBase",
      "displayName": "HLG Base",
      "type": "module",
      "version": "2.0.0",
      "description": "Glue code for HLG-Module on new-gen SA. Ships SA wrapper, GameManager, LevelSpawner, LevelData base, GameSettings/ColorData scripts, color materials, fonts, and a Game.prefab (GameManager + LevelSpawner). Post-install: deletes any pre-existing ColorData.cs/asset, moves project's GameSettings.asset to Resources/, instantiates Game.prefab into Game.unity, rewires GameManager.settings + GameSettings.colorData, and sets Game.unity main camera to the HLG ortho preset.",
      "sourcePaths": [
        "Assets/Modules/HLGBase/Scripts",
        "Assets/Modules/HLGBase/Materials",
        "Assets/Modules/HLGBase/Fonts",
        "Assets/Modules/HLGBase/Prefabs",
        "Assets/Modules/HLGBase/Resources/ColorData.asset",
        "Assets/Modules/HLGBase/Resources/GameSettings.asset"
      ],
      "pathOverrides": [
        { "src": "Assets/Modules/HLGBase/Resources/ColorData.asset", "dest": "Assets/Resources/ColorData.asset" },
        { "src": "Assets/Modules/HLGBase/Resources/GameSettings.asset", "dest": "Assets/Resources/GameSettings.asset" }
      ],
      "dependencies": []
    },
